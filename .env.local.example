# Copy this file to ".env.local" and fill in real values, then run `npm run dev`.
# ".env.local" is gitignored — never commit real secrets. Restart dev server after editing env.

# --- Supabase (auth & database) --- REQUIRED (minimum to boot the app)
# Get these from your Supabase project: Settings > API.
# NEXT_PUBLIC_* are inlined into the browser bundle at BUILD time (public values).
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# --- Server only (never expose to the browser; do NOT prefix with NEXT_PUBLIC_) ---
# Rotate these immediately if leaked.
# Supabase service role key (Settings > API). Server reads all tasks (bypasses RLS).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Gemini API key (Google AI Studio). Powers AI内田さん (/assistant). Unset -> /assistant returns 500.
GEMINI_API_KEY=your-gemini-api-key

# --- SMTP for the progress-summary email (optional; only to send mail) ---
# SMTP_PORT defaults to 587; SMTP_FROM defaults to SMTP_USER.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user@example.com
SMTP_FROM=your-smtp-user@example.com
SMTP_PASSWORD=your-smtp-password

# --- Scheduled-mail authorization (optional; only for scheduled sends) ---
# Shared secret to authorize /api/send-summary. Generate: openssl rand -hex 32
CRON_SECRET=your-long-random-secret

# --- App URL (optional; used for links inside summary emails) ---
# Local dev: http://localhost:3000. In production, set your real site URL in Vercel.
APP_URL=http://localhost:3000

# Supabase connection info. Copy this file to ".env.local" and fill in real values.
# Find these in your Supabase project: Settings > API.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# --- Server only (never expose to the browser; do NOT prefix with NEXT_PUBLIC_) ---
# Supabase service role key (Settings > API). Lets server code read all tasks (bypasses RLS).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# SMTP for sending the progress-summary email.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user@example.com
SMTP_FROM=your-smtp-user@example.com
SMTP_PASSWORD=your-smtp-password

# Copy this file to .env.test (gitignored) and fill in real values.
# Used by the authenticated Playwright E2E (npm run test:e2e).
# Keeping creds here means they are NOT typed into your shell (no history leak).

# Test account used to log in during E2E. Use a throwaway/test user.
TEST_EMAIL=you@example.com
TEST_PASSWORD=change-me

# Optional: target a preview/local instead of production.
# E2E_BASE_URL=https://manage-task-drab.vercel.app
